LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

OPENAI_API_KEY=your-openai-api-key

NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

LLM_MODEL=deepseek-chat
EMBEDDING_MODEL=text-embedding-3-large
VECTOR_INDEX_NAME=chunk_vector_index
LOCAL_EMBEDDING_PROVIDER=qwen
LOCAL_EMBEDDING_MODEL_PATH=C:\path\to\Qwen3-Embedding-0___6B
LOCAL_EMBEDDING_DEVICE=cpu
LOCAL_EMBEDDING_DIMENSIONS=1024
LOCAL_EMBEDDING_NORMALIZE=true
CHUNK_LABEL=Chunk
CHUNK_TEXT_PROPERTY=text
CHUNK_EMBEDDING_PROPERTY=embedding
