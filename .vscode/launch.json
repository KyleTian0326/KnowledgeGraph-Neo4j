{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Check Neo4j",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/check_neo4j.py",
      "console": "integratedTerminal"
    },
    {
      "name": "Ingest Source Pipeline",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/ingest_source_pipeline.py",
      "args": ["--source", "source", "--workers", "3"],
      "console": "integratedTerminal"
    },
    {
      "name": "Evaluate Retrieval",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/evaluate_graphrag_retrieval.py",
      "args": ["--dataset", "eval/retrieval_eval.example.jsonl", "--ks", "3,5,10", "--graph-ks", "5,10", "--output", "output/retrieval_eval_example.json"],
      "console": "integratedTerminal"
    },
    {
      "name": "Audit Page Continuity",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/audit_page_continuity.py",
      "args": ["--input", "data/pipeline_20260522_110658", "--output", "output/page_continuity_audit.json"],
      "console": "integratedTerminal"
    },
    {
      "name": "Start Web GraphRAG Chat",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/web_graphrag_chat.py",
      "console": "integratedTerminal"
    }
  ]
}
